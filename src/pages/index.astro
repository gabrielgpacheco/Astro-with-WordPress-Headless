---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import TeamSection from '../components/TeamSection.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import CTASection from '../components/CTASection.astro';
---

<Layout title="Home - Sterling Law Firm">
	<HeroSection 
		title="Trusted Legal Representation"
		subtitle="Experienced attorneys dedicated to protecting your rights and interests"
		ctaText="Schedule Free Consultation"
		ctaLink="/contact"
	/>
	<ServicesSection />
	<TeamSection />
	<TestimonialsSection />
	<CTASection 
		title="Ready to Discuss Your Legal Matter?"
		description="Our experienced attorneys are here to provide the representation you deserve. Contact us today for a confidential consultation."
		buttonText="Get Started"
		buttonLink="/contact"
	/>
</Layout>
