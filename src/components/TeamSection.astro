---
interface TeamMember {
	name: string;
	title: string;
	specialties: string;
	image: string;
}

const team: TeamMember[] = [
	{
		name: "Margaret Sterling",
		title: "Managing Partner",
		specialties: "Corporate Law, M&A",
		image: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=300&h=300&fit=crop"
	},
	{
		name: "James Mitchell",
		title: "Senior Counsel",
		specialties: "Litigation, Employment Law",
		image: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=300&h=300&fit=crop"
	},
	{
		name: "Victoria Chen",
		title: "Associate Attorney",
		specialties: "Real Estate, Property Law",
		image: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=300&h=300&fit=crop"
	},
	{
		name: "David Rodriguez",
		title: "Associate Attorney",
		specialties: "Intellectual Property, Patents",
		image: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=300&h=300&fit=crop"
	}
];
---

<section class="team">
	<div class="container">
		<div class="section-header">
			<h2>Our Team</h2>
			<p>Meet our experienced and dedicated legal professionals</p>
		</div>
		<div class="team-grid">
			{team.map((member) => (
				<div class="team-card">
					<img src={member.image} alt={member.name} class="team-image" />
					<div class="team-info">
						<h3>{member.name}</h3>
						<p class="title">{member.title}</p>
						<p class="specialties">{member.specialties}</p>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.team {
		padding: 80px 0;
		background-color: white;
	}

	.section-header {
		text-align: center;
		margin-bottom: 60px;
	}

	.section-header h2 {
		font-family: "Playfair Display", serif;
		font-size: 42px;
		color: #1a3a52;
		margin-bottom: 15px;
	}

	.section-header p {
		font-size: 18px;
		color: #666;
	}

	.team-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 40px;
	}

	.team-card {
		text-align: center;
		transition: all 0.3s ease;
	}

	.team-card:hover {
		transform: translateY(-5px);
	}

	.team-image {
		width: 100%;
		height: 280px;
		object-fit: cover;
		border-radius: 8px;
		margin-bottom: 20px;
		display: block;
		box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
	}

	.team-info h3 {
		font-family: "Playfair Display", serif;
		font-size: 22px;
		color: #1a3a52;
		margin-bottom: 8px;
	}

	.title {
		font-weight: 600;
		color: #d4af37;
		font-size: 14px;
		margin-bottom: 8px;
	}

	.specialties {
		color: #666;
		font-size: 14px;
		line-height: 1.6;
	}

	@media (max-width: 768px) {
		.team {
			padding: 50px 0;
		}

		.section-header h2 {
			font-size: 32px;
		}

		.team-grid {
			grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
			gap: 30px;
		}

		.team-image {
			height: 200px;
		}
	}
</style>
